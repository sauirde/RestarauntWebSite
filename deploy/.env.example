# ============================================================================
#  Production .env — скопируйте в deploy/.env и заполните реальными значениями.
#  НЕ коммитьте deploy/.env в git.
# ============================================================================

# --- Django ----------------------------------------------------------------
SECRET_KEY=ЗАМЕНИТЕ-на-случайную-строку-не-короче-50-символов
DEBUG=False
ALLOWED_HOSTS=example.com,www.example.com

# --- PostgreSQL (используются сервисом `db` в docker-compose) ---------------
POSTGRES_DB=restaurant
POSTGRES_USER=restaurant
POSTGRES_PASSWORD=ЗАМЕНИТЕ-на-сильный-пароль

# --- База данных для Django ------------------------------------------------
# host = имя сервиса из docker-compose (db). Значения должны совпадать
# с POSTGRES_* выше.
DATABASE_URL=postgres://restaurant:ЗАМЕНИТЕ-на-сильный-пароль@db:5432/restaurant

# --- HTTPS / безопасность --------------------------------------------------
# Пока TLS НЕ настроен — поставьте False (иначе бесконечный редирект на https).
# После установки сертификатов верните True.
SECURE_SSL_REDIRECT=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False
CSRF_TRUSTED_ORIGINS=https://example.com,https://www.example.com

# --- CORS (фронтенд) -------------------------------------------------------
CORS_ALLOWED_ORIGINS=https://example.com,https://www.example.com

# --- SMS-провайдер ---------------------------------------------------------
SMS_ENABLED=True
SMS_API_URL=https://api.sms-provider.example/send
SMS_API_KEY=ЗАМЕНИТЕ-на-ключ-провайдера
SMS_SENDER=Bereke
SMS_TIMEOUT=10

# --- Email (SMTP) ----------------------------------------------------------
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_HOST_USER=no-reply@example.com
EMAIL_HOST_PASSWORD=ЗАМЕНИТЕ-на-пароль-почты
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=Bereke <no-reply@example.com>
MANAGER_EMAIL=manager@example.com
